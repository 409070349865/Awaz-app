# ══════════════════════════════════════════════════════════════════
#  AWAZ (آواز) — Environment Variables
#  Copy this file to  .env  and fill in your values.
#  Never commit  .env  to version control.
# ══════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production           # 'development' | 'production'
LOG_LEVEL=info                # 'debug' | 'info' | 'warn' | 'error'

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Leave blank (or set to '*') to allow all origins (dev only).
ALLOWED_ORIGINS=https://your-frontend-domain.com

# ── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_MAX=60             # Max requests per IP per minute (global)

# ── Request Timeout ───────────────────────────────────────────────
REQUEST_TIMEOUT_MS=7000       # 7 seconds

# ══════════════════════════════════════════════════════════════════
#  CHOOSE ONE translation engine and fill in its credentials below.
#  Set TRANSLATE_ENGINE to one of:
#    libretranslate | google | deepl | openai
# ══════════════════════════════════════════════════════════════════
TRANSLATE_ENGINE=libretranslate

# ── LibreTranslate (FREE — recommended for getting started) ───────
LIBRETRANSLATE_URL=https://libretranslate.com
LIBRETRANSLATE_APIKEY=               # Get a free key at libretranslate.com

# ── Google Cloud Translation v2 ───────────────────────────────────
# https://console.cloud.google.com → APIs → Cloud Translation API
GOOGLE_TRANSLATE_API_KEY=

# ── DeepL ─────────────────────────────────────────────────────────
# https://www.deepl.com/pro-api  (free tier: 500k chars/month)
DEEPL_API_KEY=
DEEPL_API_URL=https://api-free.deepl.com   # Use api.deepl.com for Pro

# ── OpenAI ────────────────────────────────────────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini      # fast + cheap; use gpt-4o for highest quality
